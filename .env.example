# Exchange settings
EXCHANGE_ID=binance
EXCHANGE_API_KEY=
EXCHANGE_SECRET=
EXCHANGE_PASSWORD=          # if required by exchange

# Trading mode: paper or live
TRADING_MODE=paper

# Base currency (e.g., USDT, BTC)
BASE_CURRENCY=USDT

# Maximum number of coins to trade simultaneously (default 10)
MAX_COINS=10

# Paper trading initial balance (only used in paper mode)
PAPER_INITIAL_BALANCE=10000.0

# LLM Provider: "ollama" or "openai"
LLM_PROVIDER=ollama

# Ollama settings (used when LLM_PROVIDER=ollama)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=deepseek-v4-flash
# OLLAMA_API_KEY=             # leave empty if not needed

# OpenAI-compatible API settings (used when LLM_PROVIDER=openai)
# OPENAI_API_KEY=sk-...
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_MODEL=gpt-4o

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0

# News sources (comma-separated, supported: newsapi, twitter, reddit)
NEWS_SOURCES=["newsapi"]
NEWS_API_KEY=
TWITTER_BEARER_TOKEN=
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=trading-bot/1.0
NEWS_MAX_ARTICLES_PER_SYMBOL=5
NEWS_CACHE_TTL_SECONDS=900

# Facebook (Graph API)
FACEBOOK_PAGE_ACCESS_TOKEN=
FACEBOOK_PAGE_ID=
FACEBOOK_POST_LIMIT=5

# RSS Feeds (comma-separated list of feed URLs)
RSS_FEEDS=["https://www.coindesk.com/arc/outboundfeeds/rss/","https://cointelegraph.com/rss","https://decrypt.co/feed"]

# YouTube Data API v3
YOUTUBE_API_KEY=
YOUTUBE_MAX_RESULTS=5

# CryptoPanic API
CRYPTOPANIC_API_KEY=
CRYPTOPANIC_MAX_POSTS=5

# CoinGecko News (free, no API key required)
COINGECKO_MAX_ARTICLES=5

# CryptoCompare News API
CRYPTOCOMPARE_API_KEY=
CRYPTOCOMPARE_MAX_ARTICLES=5

# LunarCrush API
LUNARCRUSH_API_KEY=
LUNARCRUSH_MAX_ARTICLES=5

# Santiment API
SANTIMENT_API_KEY=
SANTIMENT_MAX_ARTICLES=5

# Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=           # optional, can be set via /start

# Web interface
WEB_HOST=0.0.0.0
WEB_PORT=8083

# Logging
LOG_LEVEL=INFO
