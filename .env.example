# Exchange settings
EXCHANGE_ID=binance
EXCHANGE_API_KEY=
EXCHANGE_SECRET=
EXCHANGE_PASSWORD=          # if required by exchange
# CoinMarketCap API key for altcoin season index (free tier)
CMC_API_KEY=

# Trading mode: paper or live
TRADING_MODE=paper

# Base currency (e.g., USDT, BTC)
BASE_CURRENCY=USDT

# Maximum number of coins to trade simultaneously (default 10)
MAX_COINS=10

# Excluded coin pairs / timeframes from coin selection.
# Format: "SYMBOL" or "SYMBOL/*" to exclude all timeframes,
#         "SYMBOL/TIMEFRAME" to exclude only that timeframe.
# Example: EXCLUDED_PAIRS=["BTC/USDT","ETH/USDT/5m"]
EXCLUDED_PAIRS=[]

# Paper trading initial balance (only used in paper mode)
PAPER_INITIAL_BALANCE=10000.0

# LLM Provider: "ollama" or "openai"
LLM_PROVIDER=ollama

# Ollama settings (used when LLM_PROVIDER=ollama)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=deepseek-v4-flash
# OLLAMA_API_KEY=             # leave empty if not needed

# OpenAI-compatible API settings (used when LLM_PROVIDER=openai)
# OPENAI_API_KEY=sk-...
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_MODEL=gpt-4o

# Mind model (complex reasoning) - used for coin selection and strategy generation
OLLAMA_MIND_MODEL=deepseek-v4-flash
OPENAI_MIND_MODEL=gpt-4o

# Actuator model (fast operations) - used for critical decisions (stop-loss, take-profit, etc.)
OLLAMA_ACTUATOR_MODEL=deepseek-v4-flash
OPENAI_ACTUATOR_MODEL=gpt-4o-mini

# Per‑role provider overrides (empty = use global LLM_PROVIDER)
# This allows the mind and actuator to use completely different providers.
# For example, mind=openai with a powerful model, actuator=ollama with a fast local model.
# LLM_MIND_PROVIDER=openai
# LLM_ACTUATOR_PROVIDER=ollama

# Per‑role OpenAI settings (empty = use global OPENAI_*)
# OPENAI_MIND_API_KEY=sk-...
# OPENAI_ACTUATOR_API_KEY=sk-...
# OPENAI_MIND_BASE_URL=https://api.openai.com/v1
# OPENAI_ACTUATOR_BASE_URL=https://api.openai.com/v1

# Per‑role Ollama settings (empty = use global OLLAMA_*)
# OLLAMA_MIND_BASE_URL=http://localhost:11434
# OLLAMA_ACTUATOR_BASE_URL=http://localhost:11434
# OLLAMA_MIND_API_KEY=
# OLLAMA_ACTUATOR_API_KEY=

# LLM temperature (0.0–2.0, lower = more deterministic; default 0.1)
LLM_TEMPERATURE=0.1

# Per‑role temperature overrides (optional).
# Can be a single float (e.g. 0.2) or a range "min-max" (e.g. "0.2-0.5").
# If a range is given, the engine picks a temperature inside it based on
# prompt complexity (higher complexity → higher temperature).
# If not set, the global LLM_TEMPERATURE is used.
# LLM_MIND_TEMPERATURE=0.2-0.5
# LLM_ACTUATOR_TEMPERATURE=0.0-0.2

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0

# News / Sentiment – set the API keys for the sources you want to use.
# Sources are enabled automatically when their required keys are provided.
NEWS_ENABLED=false
NEWS_API_KEY=
TWITTER_BEARER_TOKEN=
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=trading-bot/1.0
NEWS_MAX_ARTICLES_PER_SYMBOL=5
NEWS_CACHE_TTL_SECONDS=900
NEWS_HTTP_TIMEOUT_SECONDS=30.0
NEWS_INITIAL_FETCH_TIMEOUT_SECONDS=60.0
NEWS_RETENTION_SECONDS=86400

# Facebook (Graph API)
FACEBOOK_PAGE_ACCESS_TOKEN=
FACEBOOK_PAGE_ID=
FACEBOOK_POST_LIMIT=5

# RSS Feeds (comma-separated list of feed URLs)
RSS_FEEDS=["https://www.coindesk.com/arc/outboundfeeds/rss/","https://cointelegraph.com/rss","https://decrypt.co/feed","https://www.theblock.co/rss","https://cryptoslate.com/feed/","https://ambcrypto.com/feed/","https://bitcoinmagazine.com/.rss/full/","https://bitcoinist.com/feed/","https://www.newsbtc.com/feed/","https://cryptopotato.com/feed/","https://coinjournal.net/feed/","https://cryptobriefing.com/feed/","https://beincrypto.com/feed/","https://coingape.com/feed/","https://dailyhodl.com/feed/","https://www.cryptonewsz.com/feed/","https://www.cryptopolitan.com/feed/"]

# YouTube Data API v3
YOUTUBE_API_KEY=
YOUTUBE_MAX_RESULTS=5

# CryptoPanic API
CRYPTOPANIC_API_KEY=
CRYPTOPANIC_MAX_POSTS=5

# CryptoCompare News API
CRYPTOCOMPARE_API_KEY=
CRYPTOCOMPARE_MAX_ARTICLES=5

# LunarCrush API
LUNARCRUSH_API_KEY=
LUNARCRUSH_MAX_ARTICLES=5

# Santiment API
SANTIMENT_API_KEY=
SANTIMENT_MAX_ARTICLES=5

# Messari API
MESSARI_API_KEY=
MESSARI_MAX_ARTICLES=5

# CoinMarketCap API
COINMARKETCAP_API_KEY=
COINMARKETCAP_MAX_ARTICLES=5

# Google News RSS (free, no API key)
GOOGLE_NEWS_MAX_ARTICLES=5

# StockTwits API
STOCKTWITS_API_KEY=
STOCKTWITS_MAX_POSTS=5

# News sentiment risk adjustment
NEWS_SENTIMENT_RISK_ADJUSTMENT=false
NEWS_SENTIMENT_NEGATIVE_THRESHOLD=-0.5
NEWS_SENTIMENT_POSITIVE_THRESHOLD=0.5
NEWS_SENTIMENT_POSITION_SIZE_MULTIPLIER_NEGATIVE=0.5
NEWS_SENTIMENT_POSITION_SIZE_MULTIPLIER_POSITIVE=1.0
NEWS_SENTIMENT_SKIP_BUY_ON_VERY_NEGATIVE=true

# News sentiment risk management for open positions
NEWS_SENTIMENT_EXIT_ON_VERY_NEGATIVE=false
NEWS_SENTIMENT_EXIT_THRESHOLD=-0.7
NEWS_SENTIMENT_TIGHTEN_STOP=false
NEWS_SENTIMENT_TIGHTEN_STOP_THRESHOLD=-0.3
NEWS_SENTIMENT_TIGHTEN_STOP_MULTIPLIER=0.5

# News-driven coin discovery
NEWS_COIN_DISCOVERY_ENABLED=false
NEWS_COIN_DISCOVERY_MAX_COINS=5
NEWS_COIN_DISCOVERY_MIN_SENTIMENT=0.3
NEWS_COIN_DISCOVERY_MIN_ARTICLES=3

# Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=           # optional, can be set via /start

# Web interface
WEB_HOST=0.0.0.0
WEB_PORT=8083

# Logging
LOG_LEVEL=INFO
